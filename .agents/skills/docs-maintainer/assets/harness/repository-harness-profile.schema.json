{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/repository-harness-profile.v1.json",
  "title": "Repository harness profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repository",
    "purpose",
    "lifecyclePhase",
    "identitySource",
    "owners",
    "commands",
    "representativeJobs",
    "criticalJourneyOwner",
    "boundaryFacts",
    "exclusions",
    "nonClaims",
    "exceptions"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "repository": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "lifecyclePhase": { "type": "string", "minLength": 1 },
    "identitySource": { "type": "string", "minLength": 1 },
    "owners": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docsRouter",
        "architecture",
        "standards",
        "readmes",
        "generatedReference",
        "runbooks",
        "proof",
        "evidence",
        "activeSpecs",
        "activePlans",
        "archives",
        "skills",
        "agentGuidance"
      ],
      "properties": {
        "docsRouter": { "$ref": "#/$defs/nonEmptyString" },
        "architecture": { "$ref": "#/$defs/paths" },
        "standards": { "$ref": "#/$defs/paths" },
        "readmes": { "$ref": "#/$defs/paths" },
        "generatedReference": { "$ref": "#/$defs/paths" },
        "runbooks": { "$ref": "#/$defs/paths" },
        "proof": { "$ref": "#/$defs/paths" },
        "evidence": { "$ref": "#/$defs/paths" },
        "activeSpecs": { "$ref": "#/$defs/paths" },
        "activePlans": { "$ref": "#/$defs/paths" },
        "archives": { "$ref": "#/$defs/paths" },
        "skills": { "$ref": "#/$defs/paths" },
        "agentGuidance": { "$ref": "#/$defs/paths" }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documentation", "skills", "focused", "closeout"],
      "properties": {
        "documentation": { "$ref": "#/$defs/commands" },
        "skills": { "$ref": "#/$defs/commands" },
        "focused": { "$ref": "#/$defs/commands" },
        "closeout": { "$ref": "#/$defs/commands" }
      }
    },
    "representativeJobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "consumer", "acceptedOutcome", "owningPaths"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "consumer": { "$ref": "#/$defs/nonEmptyString" },
          "acceptedOutcome": { "$ref": "#/$defs/nonEmptyString" },
          "owningPaths": { "$ref": "#/$defs/paths" }
        }
      }
    },
    "criticalJourneyOwner": { "$ref": "#/$defs/nonEmptyString" },
    "boundaryFacts": { "$ref": "#/$defs/nonEmptyStrings" },
    "exclusions": { "$ref": "#/$defs/nonEmptyStrings" },
    "nonClaims": { "$ref": "#/$defs/nonEmptyStrings" },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "invariantId",
          "replacement",
          "rationale",
          "owner",
          "evidence",
          "reviewTrigger",
          "retirementCondition"
        ],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "invariantId": {
            "type": "string",
            "pattern": "^HC-[A-Z]+-[0-9]{3}$"
          },
          "replacement": { "$ref": "#/$defs/nonEmptyString" },
          "rationale": { "$ref": "#/$defs/nonEmptyString" },
          "owner": { "$ref": "#/$defs/nonEmptyString" },
          "evidence": { "$ref": "#/$defs/nonEmptyStrings" },
          "reviewTrigger": { "$ref": "#/$defs/nonEmptyString" },
          "retirementCondition": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]+$" },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "paths": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    }
  }
}
