{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/harness-control-record.v1.json",
  "title": "Harness feedback and automation control record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "failureClass",
    "evidence",
    "earliestOwner",
    "acceptedMechanism",
    "signal",
    "durableState",
    "authority",
    "convergence",
    "proofPerRun",
    "boundedFailure",
    "repairRoute",
    "falsePositiveCost",
    "carryingCost",
    "reviewTrigger",
    "stopAndRollback",
    "retirementCondition",
    "disconfirmingEvidence",
    "remindersToRetire"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]+$" },
    "kind": {
      "enum": [
        "schema",
        "type",
        "api",
        "lint",
        "test",
        "fixture",
        "generator",
        "tool",
        "runbook",
        "policy",
        "automation"
      ]
    },
    "failureClass": { "$ref": "#/$defs/nonEmptyString" },
    "evidence": { "$ref": "#/$defs/nonEmptyStrings" },
    "earliestOwner": { "$ref": "#/$defs/nonEmptyString" },
    "acceptedMechanism": { "$ref": "#/$defs/nonEmptyString" },
    "signal": { "$ref": "#/$defs/nonEmptyString" },
    "durableState": { "$ref": "#/$defs/nonEmptyString" },
    "authority": { "$ref": "#/$defs/nonEmptyString" },
    "convergence": { "$ref": "#/$defs/nonEmptyString" },
    "proofPerRun": { "$ref": "#/$defs/nonEmptyString" },
    "boundedFailure": { "$ref": "#/$defs/nonEmptyString" },
    "repairRoute": { "$ref": "#/$defs/nonEmptyString" },
    "falsePositiveCost": { "$ref": "#/$defs/nonEmptyString" },
    "carryingCost": { "$ref": "#/$defs/nonEmptyString" },
    "reviewTrigger": { "$ref": "#/$defs/nonEmptyString" },
    "stopAndRollback": { "$ref": "#/$defs/nonEmptyString" },
    "retirementCondition": { "$ref": "#/$defs/nonEmptyString" },
    "disconfirmingEvidence": { "$ref": "#/$defs/nonEmptyStrings" },
    "remindersToRetire": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    }
  }
}
