{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/harness-critical-journey.v1.json",
  "title": "Harness critical journey",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "actorOrConsumer",
    "boundary",
    "startingState",
    "inputs",
    "stepsOrProcedureOwner",
    "expectedBehavior",
    "expectedSideEffects",
    "preservedInvariants",
    "oracle",
    "environment",
    "authority",
    "evidence",
    "nonClaims"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]+$" },
    "actorOrConsumer": { "$ref": "#/$defs/nonEmptyString" },
    "boundary": { "$ref": "#/$defs/nonEmptyString" },
    "startingState": { "$ref": "#/$defs/nonEmptyString" },
    "inputs": { "$ref": "#/$defs/nonEmptyStrings" },
    "stepsOrProcedureOwner": { "$ref": "#/$defs/nonEmptyString" },
    "expectedBehavior": { "$ref": "#/$defs/nonEmptyStrings" },
    "expectedSideEffects": { "$ref": "#/$defs/nonEmptyStrings" },
    "preservedInvariants": { "$ref": "#/$defs/nonEmptyStrings" },
    "oracle": { "$ref": "#/$defs/nonEmptyString" },
    "environment": { "$ref": "#/$defs/nonEmptyString" },
    "authority": { "enum": ["none", "read_only", "mutation"] },
    "evidence": { "$ref": "#/$defs/nonEmptyStrings" },
    "nonClaims": { "$ref": "#/$defs/nonEmptyStrings" }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    }
  }
}
