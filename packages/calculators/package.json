{
  "name": "@taxkit/calculators",
  "version": "1.0.0",
  "private": true,
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./catalog": {
      "source": "./src/catalog.ts",
      "types": "./dist/catalog.d.ts",
      "default": "./dist/catalog.js"
    },
    "./errors": {
      "source": "./src/errors.ts",
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./metadata": {
      "source": "./src/metadata.ts",
      "types": "./dist/metadata.d.ts",
      "default": "./dist/metadata.js"
    },
    "./service": {
      "source": "./src/service.ts",
      "types": "./dist/service.d.ts",
      "default": "./dist/service.js"
    },
    "./live": {
      "source": "./src/live.layer.ts",
      "types": "./dist/live.layer.d.ts",
      "default": "./dist/live.layer.js"
    },
    "./schemas": {
      "source": "./src/schemas.ts",
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./catalog": {
        "types": "./dist/catalog.d.ts",
        "default": "./dist/catalog.js"
      },
      "./errors": {
        "types": "./dist/errors.d.ts",
        "default": "./dist/errors.js"
      },
      "./metadata": {
        "types": "./dist/metadata.d.ts",
        "default": "./dist/metadata.js"
      },
      "./service": {
        "types": "./dist/service.d.ts",
        "default": "./dist/service.js"
      },
      "./live": {
        "types": "./dist/live.layer.d.ts",
        "default": "./dist/live.layer.js"
      },
      "./schemas": {
        "types": "./dist/schemas.d.ts",
        "default": "./dist/schemas.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test-types": "tsc -p tsconfig.type-tests.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@taxkit/core": "workspace:*",
    "@taxkit/rules-au-income-tax": "workspace:*",
    "@taxkit/rules-au-pay": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@taxkit/testing": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
