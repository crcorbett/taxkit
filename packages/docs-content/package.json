{
  "name": "@whattax/docs-content",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./errors": {
      "source": "./src/errors.ts",
      "default": "./src/errors.ts"
    },
    "./live": {
      "source": "./src/live.layer.ts",
      "default": "./src/live.layer.ts"
    },
    "./server": {
      "source": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./client": {
      "source": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./schemas": {
      "source": "./src/schemas.ts",
      "default": "./src/schemas.ts"
    },
    "./service": {
      "source": "./src/service.ts",
      "default": "./src/service.ts"
    },
    "./validate": {
      "source": "./src/validate.runtime.ts",
      "default": "./src/validate.runtime.ts"
    },
    "./source.config": "./source.config.ts"
  },
  "scripts": {
    "build": "fumadocs-mdx",
    "check-types": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "validate": "bun run ./src/validate.runtime.ts",
    "clean": "rm -rf .source .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "4.0.0-beta.60",
    "@whattax/docs-fumadocs": "workspace:*",
    "effect": "catalog:",
    "fumadocs-core": "^16.8.3",
    "fumadocs-mdx": "^14.3.1"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
