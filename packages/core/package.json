{
  "name": "@packages/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "@packages/source": "./src/seo.ts",
      "default": "./dist/seo.js"
    },
    "./*": "./*",
    "./seo": {
      "@packages/source": "./src/seo.ts",
      "default": "./dist/seo.js"
    }
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsdown": "^0.21.10",
    "typescript": "catalog:typescript"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/seo.js",
      "./*": "./*",
      "./seo": {
        "@packages/source": "./src/seo.ts",
        "default": "./dist/seo.js"
      }
    }
  }
}
