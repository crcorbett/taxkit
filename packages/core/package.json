{
  "name": "@whattax/core",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./primitives": {
      "source": "./src/primitives/index.ts",
      "types": "./dist/primitives/index.d.ts",
      "default": "./dist/primitives/index.js"
    },
    "./facts": {
      "source": "./src/facts/index.ts",
      "types": "./dist/facts/index.d.ts",
      "default": "./dist/facts/index.js"
    },
    "./parameters": {
      "source": "./src/parameters/index.ts",
      "types": "./dist/parameters/index.d.ts",
      "default": "./dist/parameters/index.js"
    },
    "./errors": {
      "source": "./src/errors/index.ts",
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./engine": {
      "source": "./src/engine/index.ts",
      "types": "./dist/engine/index.d.ts",
      "default": "./dist/engine/index.js"
    },
    "./rules": {
      "source": "./src/rules/index.ts",
      "types": "./dist/rules/index.d.ts",
      "default": "./dist/rules/index.js"
    },
    "./graph": {
      "source": "./src/graph/index.ts",
      "types": "./dist/graph/index.d.ts",
      "default": "./dist/graph/index.js"
    },
    "./trace": {
      "source": "./src/trace/index.ts",
      "types": "./dist/trace/index.d.ts",
      "default": "./dist/trace/index.js"
    },
    "./ledger": {
      "source": "./src/ledger/index.ts",
      "types": "./dist/ledger/index.d.ts",
      "default": "./dist/ledger/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
