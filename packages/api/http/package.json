{
  "name": "@whattax/api-http",
  "version": "0.1.0",
  "private": true,
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "source": "./src/api.ts",
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./client": {
      "source": "./src/client/index.ts",
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./client/live": {
      "source": "./src/client/live.layer.ts",
      "types": "./dist/client/live.layer.d.ts",
      "default": "./dist/client/live.layer.js"
    },
    "./client/server": {
      "source": "./src/client/server.layer.ts",
      "types": "./dist/client/server.layer.d.ts",
      "default": "./dist/client/server.layer.js"
    },
    "./config": {
      "source": "./src/config.ts",
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./server": {
      "source": "./src/server.ts",
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./handlers": {
      "source": "./src/handlers/index.ts",
      "types": "./dist/handlers/index.d.ts",
      "default": "./dist/handlers/index.js"
    },
    "./handlers/live": {
      "source": "./src/handlers/live.ts",
      "types": "./dist/handlers/live.d.ts",
      "default": "./dist/handlers/live.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./api": {
        "types": "./dist/api.d.ts",
        "default": "./dist/api.js"
      },
      "./client": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.js"
      },
      "./client/live": {
        "types": "./dist/client/live.layer.d.ts",
        "default": "./dist/client/live.layer.js"
      },
      "./client/server": {
        "types": "./dist/client/server.layer.d.ts",
        "default": "./dist/client/server.layer.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "default": "./dist/config.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "./handlers": {
        "types": "./dist/handlers/index.d.ts",
        "default": "./dist/handlers/index.js"
      },
      "./handlers/live": {
        "types": "./dist/handlers/live.d.ts",
        "default": "./dist/handlers/live.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:openapi": "vitest run __tests__/openapi-snapshot.test.ts",
    "update-openapi-snapshot": "UPDATE_WHATTAX_OPENAPI_SNAPSHOT=true vitest run __tests__/openapi-snapshot.test.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@whattax/calculators": "workspace:*",
    "@whattax/core": "workspace:*",
    "@whattax/sdk": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@whattax/rules-au-pay": "workspace:*",
    "@whattax/testing": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
