{
  "name": "@taxkit/rules-au-income-tax",
  "version": "0.1.0",
  "private": true,
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./facts": {
      "source": "./src/facts/index.ts",
      "types": "./dist/facts/index.d.ts",
      "default": "./dist/facts/index.js"
    },
    "./parameters": {
      "source": "./src/parameters/index.ts",
      "types": "./dist/parameters/index.d.ts",
      "default": "./dist/parameters/index.js"
    },
    "./rules": {
      "source": "./src/rules/index.ts",
      "types": "./dist/rules/index.d.ts",
      "default": "./dist/rules/index.js"
    },
    "./rule-pack": {
      "source": "./src/rule-pack/index.ts",
      "types": "./dist/rule-pack/index.d.ts",
      "default": "./dist/rule-pack/index.js"
    },
    "./calculator": {
      "source": "./src/calculator/index.ts",
      "types": "./dist/calculator/index.d.ts",
      "default": "./dist/calculator/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./facts": {
        "types": "./dist/facts/index.d.ts",
        "default": "./dist/facts/index.js"
      },
      "./parameters": {
        "types": "./dist/parameters/index.d.ts",
        "default": "./dist/parameters/index.js"
      },
      "./rules": {
        "types": "./dist/rules/index.d.ts",
        "default": "./dist/rules/index.js"
      },
      "./rule-pack": {
        "types": "./dist/rule-pack/index.d.ts",
        "default": "./dist/rule-pack/index.js"
      },
      "./calculator": {
        "types": "./dist/calculator/index.d.ts",
        "default": "./dist/calculator/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@taxkit/core": "workspace:*",
    "effect": "catalog:"
