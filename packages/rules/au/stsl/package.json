{
  "name": "@whattax/rules-au-stsl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./facts": {
      "source": "./src/facts/index.ts",
      "types": "./dist/facts/index.d.ts",
      "default": "./dist/facts/index.js"
    },
    "./parameters": {
      "source": "./src/parameters/index.ts",
      "types": "./dist/parameters/index.d.ts",
      "default": "./dist/parameters/index.js"
    },
    "./rules": {
      "source": "./src/rules/index.ts",
      "types": "./dist/rules/index.d.ts",
      "default": "./dist/rules/index.js"
    },
    "./rule-pack": {
      "source": "./src/rule-pack/index.ts",
      "types": "./dist/rule-pack/index.d.ts",
      "default": "./dist/rule-pack/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@whattax/core": "workspace:*",
    "@whattax/rules-au-pay": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@whattax/tsconfig": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
