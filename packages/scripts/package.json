{
  "name": "@taxkit/scripts",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./release-readiness": {
      "bun": "./src/release-readiness/index.ts",
      "source": "./src/release-readiness/index.ts",
      "types": "./dist/release-readiness/index.d.ts",
      "default": "./dist/release-readiness/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./release-readiness": {
        "types": "./dist/release-readiness/index.d.ts",
        "default": "./dist/release-readiness/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "release:check": "bun run src/release-readiness/release-readiness.runtime.ts",
    "release:present": "bun run src/release-readiness/present.runtime.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
