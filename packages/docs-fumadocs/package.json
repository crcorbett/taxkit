{
  "name": "@whattax/docs-fumadocs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "source": "./src/config.ts",
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./render": {
      "source": "./src/render/index.ts",
      "types": "./dist/render/index.d.ts",
      "default": "./dist/render/index.js"
    },
    "./schemas": {
      "source": "./src/schemas.ts",
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./source": {
      "source": "./src/source.ts",
      "types": "./dist/source.d.ts",
      "default": "./dist/source.js"
    },
    "./tree": {
      "source": "./src/tree.ts",
      "types": "./dist/tree.d.ts",
      "default": "./dist/tree.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@shikijs/core": "4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "@standard-schema/spec": "^1.1.0",
    "effect": "catalog:",
    "fumadocs-core": "^16.8.3",
    "fumadocs-mdx": "^14.3.1",
    "react": "catalog:",
    "remark-mermaidjs": "7.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/react": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
