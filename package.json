{
  "name": "whattax",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/rules/au/*"
    ],
    "catalog": {
      "@effect/vitest": "4.0.0-beta.60",
      "@tanstack/react-router": "1.169.2",
      "@tanstack/react-start": "1.167.65",
      "@types/node": "^24.10.1",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^5.1.1",
      "effect": "4.0.0-beta.60",
      "nitro": "3.0.260429-beta",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "typescript": "^6.0.3",
      "vite": "^8.0.11",
      "vitest": "^4.1.5"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "dev": "turbo run dev --filter=web",
    "clean": "turbo run clean",
    "check": "ultracite check --type-aware",
    "fix": "ultracite fix --type-aware",
    "knip": "knip --no-progress --no-config-hints"
  },
  "devDependencies": {
    "knip": "6.12.2",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "portless": "0.13.0",
    "turbo": "^2.6.1",
    "typescript": "^6.0.3",
    "ultracite": "^7.7.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.8"
}
