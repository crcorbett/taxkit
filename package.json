{
  "name": "whattax",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/rules/au/*"
    ],
    "catalog": {
      "@effect/platform-bun": "4.0.0-beta.60",
      "@effect/vitest": "4.0.0-beta.60",
      "@tanstack/react-router": "1.169.2",
      "@tanstack/react-start": "1.167.65",
      "@types/bun": "1.3.14",
      "@types/node": "^24.10.1",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^5.1.1",
      "effect": "4.0.0-beta.60",
      "nitro": "3.0.260429-beta",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "typescript": "^5.9.3",
      "vite": "^8.0.11",
      "vitest": "^4.1.5"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "check": "ultracite check --type-aware",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean",
    "dev": "portless proxy start --https && turbo run dev --filter=api --filter=web",
    "fix": "ultracite fix --type-aware",
    "format": "oxfmt -c oxfmt.config.ts --write . --no-error-on-unmatched-pattern",
    "format:check": "oxfmt -c oxfmt.config.ts --check . --no-error-on-unmatched-pattern",
    "knip": "knip --no-progress --no-config-hints",
    "lint": "oxlint -c oxlint.config.ts . --no-error-on-unmatched-pattern",
    "test": "turbo run test",
    "verification": "bun run lint && bun run format:check && bun run knip && bun run check-types",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "knip": "6.14.2",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "portless": "0.13.0",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "ultracite": "7.7.0"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24.16.0"
  },
  "packageManager": "bun@1.3.14"
}
