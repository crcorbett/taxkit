{
  "name": "whattax",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "dev": "turbo run dev --filter=web",
    "clean": "turbo run clean",
    "check": "ultracite check --type-aware",
    "fix": "ultracite fix --type-aware",
    "knip": "knip --no-progress --no-config-hints"
  },
  "devDependencies": {
    "knip": "6.12.2",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "portless": "0.13.0",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "ultracite": "^7.7.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.22.0"
}
