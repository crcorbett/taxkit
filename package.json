{
  "name": "taxkit",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/api/*",
      "packages/sdk/*",
      "packages/rules/au/*"
    ],
    "catalog": {
      "@effect/language-service": "0.87.0",
      "@effect/platform-bun": "4.0.0-beta.98",
      "@effect/platform-node": "4.0.0-beta.98",
      "@effect/vitest": "4.0.0-beta.98",
      "@tanstack/react-router": "1.169.2",
      "@tanstack/react-start": "1.167.65",
      "@types/bun": "1.3.14",
      "@types/node": "^24.10.1",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^5.1.1",
      "effect": "4.0.0-beta.98",
      "nitro": "3.0.260429-beta",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "typescript": "^5.9.3",
      "vite": "^8.0.11",
      "vitest": "^4.1.5"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "check": "ultracite check --type-aware",
    "check:effect-language-service": "effect-language-service check && tsc --noEmit -p tools/effect-language-service/tsconfig.json",
    "check-types": "turbo run check-types",
    "check:repository-paths": "bun run tools/repository-paths/check.runtime.ts",
    "check:repository-paths:types": "tsc --noEmit -p tools/repository-paths/tsconfig.json",
    "clean": "turbo run clean",
    "dev": "portless proxy start --https && turbo run dev --filter=api --filter=web",
    "docs:build": "bun run --filter=docs build",
    "docs:validate": "bun run --filter=@taxkit/docs-content validate",
    "fix": "ultracite fix --type-aware",
    "format": "oxfmt -c oxfmt.config.ts --write . --no-error-on-unmatched-pattern",
    "format:check": "oxfmt -c oxfmt.config.ts --check . --no-error-on-unmatched-pattern",
    "knip": "knip --no-progress --no-config-hints",
    "knip:production": "knip --production --config knip.production.json --no-progress --no-config-hints",
    "lint": "bun run lint:boundary-directives && oxlint -c oxlint.config.ts . --disable-nested-config --no-error-on-unmatched-pattern",
    "lint:boundary-directives": "oxlint -c oxlint.config.ts . --allow=taxkit/no-decoding-outside-boundaries --allow=taxkit/no-route-transport-restore-outside-consumers --report-unused-disable-directives-severity=error --disable-nested-config --no-error-on-unmatched-pattern",
    "prepare": "effect-language-service patch",
    "release:check": "bun run --filter=@taxkit/scripts release:check",
    "test": "bun run test:repository-paths && bun run test:docs-boundaries && bun run test:oxlint && turbo run test",
    "test:docs-boundaries": "bun test apps/docs/src/lib/docs/route-boundary.test.js",
    "test:oxlint": "bun test tools/oxlint",
    "test:repository-paths": "bun test tools/repository-paths",
    "test:skills": "bun test tools/skills",
    "verification": "bun run check:repository-paths:types && bun run check:repository-paths && bun run check:effect-language-service && bun run lint && bun run format:check && bun run test:skills && bun run knip && bun run knip:production && bun run check-types",
    "version-packages": "changeset version",
    "version-repo": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@types/bun": "catalog:",
    "effect": "catalog:",
    "knip": "6.14.2",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "portless": "0.13.0",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "ultracite": "7.7.0"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24.16.0"
  },
  "packageManager": "bun@1.3.14"
}
