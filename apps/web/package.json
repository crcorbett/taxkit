{
  "name": "web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "TAXKIT_API_BASE_URL=$(portless get api.taxkit) VITE_TAXKIT_API_BASE_URL=$(portless get api.taxkit) portless run --name taxkit vite dev",
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .output .tanstack .turbo node_modules/.vite"
  },
  "dependencies": {
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@taxkit/api-http": "workspace:*",
    "effect": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "nitro": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
