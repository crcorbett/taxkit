{
  "name": "docs",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "portless run --name docs.whattax vite dev",
    "build": "vite build",
    "check-examples": "tsc -p tsconfig.examples.json --noEmit",
    "check-types": "tsc --noEmit && bun run check-examples",
    "clean": "rm -rf .output .tanstack .turbo node_modules/.vite"
  },
  "dependencies": {
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@whattax/docs-content": "workspace:*",
    "@whattax/docs-fumadocs": "workspace:*",
    "effect": "catalog:",
    "fumadocs-mdx": "^14.3.1",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "nitro": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
