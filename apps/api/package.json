{
  "name": "api",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "portless run --name api.taxkit bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "smoke": "bun run smoke:public-routes",
    "smoke:public-routes": "bun scripts/smoke-public-routes.runtime.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:",
    "@taxkit/api-http": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@taxkit/core": "workspace:*",
    "@taxkit/rules-au-pay": "workspace:*",
    "@taxkit/tsconfig": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
