{
  "$schema": "./node_modules/knip/schema.json",
  "ignore": ["docs/**", "apps/web/src/routeTree.gen.ts"],
  "ignoreDependencies": ["@taxkit/tsconfig"],
  "ignoreIssues": {
    "apps/web/src/lib/route-runtime.ts": ["types"],
    "packages/api/http/src/client/in-process.layer.ts": ["exports"],
    "packages/api/http/src/client/service.ts": ["duplicates"],
    "packages/api/http/src/groups/health.ts": ["exports", "types"]
  },
  "ignoreBinaries": ["oxlint", "oxfmt"],
  "workspaces": {
    ".": {
      "entry": [
        "package.json",
        "turbo.json",
        "oxfmt.config.ts",
        "oxlint.config.ts",
        "tools/effect-language-service/compatibility.ts",
        "tools/repository-paths/check.runtime.ts",
        "tools/repository-paths/*.test.ts",
        "tools/quality-workflow/check.runtime.ts",
        "tools/quality-workflow/*.test.ts"
      ],
      "project": [
        "*.json",
        "*.ts",
        "tools/effect-language-service/**/*.ts",
        "tools/repository-paths/**/*.ts",
        "tools/quality-workflow/**/*.ts"
      ],
      "ignoreDependencies": ["typescript"]
    },
    "apps/api": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@taxkit/tsconfig"]
    },
    "apps/web": {
      "entry": [
        "src/router.tsx",
        "src/server.ts",
        "src/routes/**/*.{ts,tsx}",
        "vite.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "vite.config.ts"],
      "ignoreDependencies": ["@tanstack/router-plugin", "@taxkit/tsconfig"]
    },
    "apps/docs": {
      "entry": [
        "src/lib/docs/route-boundary.type-test.ts",
        "src/router.tsx",
        "src/server.ts",
        "src/routes/**/*.{ts,tsx}",
        "vite.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "vite.config.ts"],
      "ignore": ["examples/**/*.ts", "src/routeTree.gen.ts"],
      "ignoreDependencies": ["@taxkit/tsconfig"]
    },
    "packages/core": {
      "entry": ["src/index.ts", "src/*/index.ts", "vitest.config.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
    },
    "packages/api/http": {
      "entry": [
        "src/index.ts",
        "src/api.ts",
        "src/client/index.ts",
        "src/client/live.layer.ts",
        "src/client/server.layer.ts",
        "src/server.ts",
        "src/handlers/index.ts",
        "src/handlers/live.ts"
      ],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@effect/platform-node", "@taxkit/tsconfig"]
    },
    "packages/calculators": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/docs-content": {
      "entry": ["source.config.ts", "src/errors.ts", "src/schemas.ts"],
      "project": ["source.config.ts", "src/**/*.ts"],
      "ignoreDependencies": ["@shikijs/core", "@taxkit/tsconfig", "typescript"]
    },
    "packages/sdk/typescript": {
      "entry": [
        "src/index.ts",
        "src/effect.ts",
        "src/au.ts",
        "src/au-effect.ts",
        "src/schemas/index.ts",
        "src/testing/index.ts",
        "scripts/check-import-boundaries.ts"
      ],
      "project": ["src/**/*.ts", "scripts/**/*.ts"],
      "ignoreDependencies": ["@types/bun"]
    },
    "packages/scripts": {
      "entry": [
        "src/index.ts",
        "src/release-readiness/release-readiness.runtime.ts"
      ],
      "project": ["src/**/*.ts", "vitest.config.ts"]
    },
    "packages/rules/au/income-tax": {
      "entry": ["src/index.ts", "src/*/index.ts", "vitest.config.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
    },
    "packages/rules/au/pay": {
      "entry": ["src/index.ts", "src/*/index.ts", "vitest.config.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
    },
    "packages/rules/au/stsl": {
      "entry": ["src/index.ts", "src/*/index.ts", "vitest.config.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
    }
  }
}
