{
  "$schema": "./node_modules/knip/schema.json",
  "ignore": ["docs/**", "apps/web/src/routeTree.gen.ts"],
  "ignoreDependencies": ["@whattax/tsconfig"],
  "ignoreIssues": {
    "apps/web/src/lib/route-runtime.ts": ["types"],
    "packages/http-api/src/client/in-process.layer.ts": ["exports"],
    "packages/http-api/src/client/service.ts": ["duplicates"],
    "packages/http-api/src/groups/health.ts": ["exports", "types"]
  },
  "ignoreBinaries": ["oxlint", "oxfmt"],
  "workspaces": {
    ".": {
      "entry": [
        "package.json",
        "turbo.json",
        "oxfmt.config.ts",
        "oxlint.config.ts"
      ],
      "project": ["*.json", "*.ts"],
      "ignoreDependencies": ["typescript"]
    },
    "apps/api": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@whattax/tsconfig"]
    },
    "apps/web": {
      "entry": [
        "src/router.tsx",
        "src/server.ts",
        "src/routes/**/*.{ts,tsx}",
        "vite.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "vite.config.ts"],
      "ignoreDependencies": ["@tanstack/router-plugin", "@whattax/tsconfig"]
    },
    "packages/core": {
      "entry": ["src/index.ts", "src/*/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/http-api": {
      "entry": [
        "src/index.ts",
        "src/api.ts",
        "src/client/index.ts",
        "src/client/live.layer.ts",
        "src/client/server.layer.ts",
        "src/server.ts",
        "src/handlers/index.ts",
        "src/handlers/live.ts"
      ],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@effect/platform-node", "@whattax/tsconfig"]
    },
    "packages/rules/au/income-tax": {
      "entry": ["src/index.ts", "src/*/index.ts", "vitest.config.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
    },
    "packages/rules/au/pay": {
      "entry": ["src/index.ts", "src/*/index.ts", "vitest.config.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
    },
    "packages/rules/au/stsl": {
      "entry": ["src/index.ts", "src/*/index.ts", "vitest.config.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
    }
  }
}
